# ── Application ──────────────────────────────────────────────────
APP_NAME=SafeNet AI
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_SECRETS_MANAGER
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEBUG=true

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=safenet
POSTGRES_USER=safenet_user
POSTGRES_PASSWORD=safenet_pass
DATABASE_URL=postgresql+asyncpg://safenet_user:safenet_pass@localhost:5432/safenet

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Neo4j (Fraud Graph) ───────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_pass

# ── Qdrant (Vector Store for RAG) ────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=safenet_docs

# ── OpenAI (CitizenShield LLM) ───────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Model Paths ──────────────────────────────────────────────────
SCAM_MODEL_PATH=./ml_training/scam/checkpoints/best_model
COUNTERFEIT_MODEL_PATH=./ml_training/counterfeit/checkpoints/best_yolo.pt
FRAUD_GNN_MODEL_PATH=./ml_training/fraud_graph/checkpoints/best_gnn.pt
WHISPER_MODEL_SIZE=base          # tiny | base | small | medium | large

# ── Twilio (Alerts) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1...

# ── Mapbox (Geospatial) ──────────────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1...

# ── NCRB / Govt Data ─────────────────────────────────────────────
NCRB_DATA_PATH=./data/ncrb
RBI_CURRENCY_DATA_PATH=./data/rbi

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_CALLS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Thresholds ───────────────────────────────────────────────────
SCAM_CONFIDENCE_THRESHOLD=0.72
COUNTERFEIT_CONFIDENCE_THRESHOLD=0.85
FRAUD_GRAPH_ALERT_THRESHOLD=0.80
